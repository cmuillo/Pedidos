DATABASE_URL="postgresql://user:pass@localhost:5432/helados?schema=public"
# Secret used to sign session tokens. MUST be a long random value in production.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
# Public URL of the app. In production set it to your Railway domain (https://...).
NEXTAUTH_URL="http://localhost:3000"
# Initial admin credentials — ONLY used by the seed script to create the first
# admin user. After deploying, change the password from Admin > Empresa > Seguridad.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
